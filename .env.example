# Публичный каталог (дерево/меню/страницы категорий) кэшируется в Next ~120 с — см. lib/catalogCache.ts.
# После сохранения в админке кэш сбрасывается через POST /api/admin/revalidate-catalog (по cookie сессии).

# URL API для браузера (желательно с суффиксом /api/v1; иначе к origin добавится /api/v1 автоматически)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# URL API для сервера Next (SSR блога, прокси /api/public/blog/*, прокси регистрации /api/register/*, админка).
# Приоритет в getServerApiBase(): API_URL → BACKEND_INTERNAL_URL → NEXT_PUBLIC_API_URL → http://127.0.0.1:3001/api/v1
# В Docker часто: BACKEND_INTERNAL_URL=http://backend:3001/api/v1 (имя сервиса вместо localhost).
# Без суффикса /api/v1 у origin — добавится автоматически.
API_URL=http://127.0.0.1:3001/api/v1

# Прод: cookie админки с Secure только по HTTPS. За nginx укажите X-Forwarded-Proto (см. docs/DEPLOY.md).
# Если сайт открывается по http://IP без TLS — задайте ADMIN_COOKIE_SECURE=0
# ADMIN_COOKIE_SECURE=0
